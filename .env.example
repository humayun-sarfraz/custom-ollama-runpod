# Custom Ollama RunPod Configuration
# Copy this file to .env and adjust values as needed

# Name for your custom Ollama model
MODEL_NAME=custom-assistant

# Path to your local GGUF model file (must exist on the server)
MODEL_PATH=/workspace/models/custom-model.gguf

# Ollama server bind address (0.0.0.0 for RunPod access)
OLLAMA_HOST=0.0.0.0:11434

# Ollama API base URL (used by FastAPI wrapper)
OLLAMA_BASE_URL=http://localhost:11434

# FastAPI wrapper port
API_PORT=8000

# CORS allowed origins (comma-separated, use * for all)
ALLOWED_ORIGINS=*
